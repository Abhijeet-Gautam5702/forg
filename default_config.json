[
  {
    "pattern": ".*[Ss]creenshot.*",
    "path": "Pictures/Screenshots"
  },
  {
    "pattern": ".*\\.(png|jpeg|jpg|gif|svg|webp|bmp|ico|tiff?)$",
    "path": "Pictures"
  },
  {
    "pattern": ".*\\.(mp4|mkv|mov|avi|wmv|flv|webm|m4v)$",
    "path": "Videos"
  },
  {
    "pattern": ".*\\.(mp3|wav|flac|m4a|ogg|aac)$",
    "path": "Music"
  },
  {
    "pattern": ".*\\.pdf$",
    "path": "Documents/PDFs"
  },
  {
    "pattern": ".*\\.csv$",
    "path": "Documents/CSVs"
  },
  {
    "pattern": ".*\\.txt$",
    "path": "Documents/TXTs"
  },
  {
    "pattern": ".*\\.md$",
    "path": "Documents/Markdowns"
  },
  {
    "pattern": ".*\\.docx?$",
    "path": "Documents/DOCXs"
  },
  {
    "pattern": ".*\\.(pdf|txt|rtf|docx?|xlsx?|pptx?|odt|md|csv|epub|mobi)$",
    "path": "Documents"
  },
  {
    "pattern": ".*\\.(zip|tar|gz|rar|7z|bz2|xz)$",
    "path": "Archives"
  },
  {
    "pattern": ".*\\.(dmg|pkg|deb|rpm|exe|msi)$",
    "path": "Installers"
  }
]
